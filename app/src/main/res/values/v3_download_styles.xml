<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- V3 顶部统计胶囊 -->
    <style name="V3StatsChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/v3_stat_chip_bg</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textColor">@color/v3_text_2</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- V3 Tab 文字 -->
    <style name="V3TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- V3 状态徽章基础样式 -->
    <style name="V3StatusBadge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/v3_status_badge_bg</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">3dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>
