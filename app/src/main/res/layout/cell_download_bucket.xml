<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_v3_card"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="18dp">

    <TextView
        android:id="@+id/bucket_name"
        style="@style/textMontserratBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/v3_text_1"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/bucket_storage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_v3_pill_secondary"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="#6C5CE7"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/bucket_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_v3_pill_secondary"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="#6C5CE7"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/download_path_label_template"
        android:textColor="@color/v3_text_3"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/bucket_template"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:autofillHints=""
        android:background="@drawable/bg_v3_chip"
        android:fontFamily="monospace"
        android:importantForAutofill="no"
        android:inputType="text|textMultiLine|textNoSuggestions"
        android:maxLines="6"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        android:textColor="@color/v3_text_1"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/download_path_label_preview"
        android:textColor="@color/v3_text_3"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/bucket_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_v3_chip"
        android:fontFamily="monospace"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        android:textColor="@color/v3_text_1"
        android:textIsSelectable="true"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/bucket_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_v3_pill_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="22dp"
            android:paddingVertical="11dp"
            android:text="@string/download_path_btn_save"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/bucket_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_v3_pill_secondary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingVertical="11dp"
            android:text="@string/download_path_btn_reset"
            android:textColor="#6C5CE7"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
