<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_upscale_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="40dp">

        <!-- Hero header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/string_ai_upscale_hero_title"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.5"
                android:text="@string/string_ai_upscale_hero_subtitle"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Model selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/chip_cugan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_model_chip_selected"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:id="@+id/chip_cugan_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-CUGAN"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chip_cugan_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="B站动漫专用，画质好"
                    android:textColor="@color/colorWhite40"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chip_esrgan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_model_chip_unselected"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:id="@+id/chip_esrgan_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-ESRGAN"
                    android:textColor="@color/colorWhite50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chip_esrgan_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="通用超分，速度快"
                    android:textColor="@color/colorWhite25"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Image pick / preview card -->
        <FrameLayout
            android:id="@+id/image_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_upscale_glass_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:minHeight="280dp">

            <!-- Empty state: dashed pick area -->
            <LinearLayout
                android:id="@+id/pick_empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="16dp"
                android:background="@drawable/bg_upscale_pick_area"
                android:gravity="center"
                android:minHeight="248dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_upscale_add_photo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/string_ai_upscale_pick_hint"
                    android:textColor="@color/colorWhite30"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_pick_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/refresh_button_background"
                    android:gravity="center"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="10dp"
                    android:stateListAnimator="@animator/button_press_alpha"
                    android:text="@string/string_ai_upscale_pick_image"
                    android:textAllCaps="false"
                    android:textColor="@color/colorWhite60"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Preview state: selected image -->
            <LinearLayout
                android:id="@+id/preview_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/image_preview_container"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="@drawable/bg_upscale_image_preview"
                    android:clipToOutline="true">

                    <ImageView
                        android:id="@+id/image_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <!-- Upscale overlay, clipped to image bounds -->
                    <include layout="@layout/view_ai_upscale_overlay" />

                    <!-- Re-pick button overlay top-right -->
                    <TextView
                        android:id="@+id/btn_repick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/refresh_button_background"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:stateListAnimator="@animator/button_press_alpha"
                        android:text="更换"
                        android:textAllCaps="false"
                        android:textColor="@color/colorWhite60"
                        android:textSize="12sp" />
                </FrameLayout>

                <!-- Resolution badge -->
                <TextView
                    android:id="@+id/resolution_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_upscale_resolution_badge"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textColor="#9B8CF6"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ready_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/string_ai_upscale_ready"
                    android:textColor="@color/colorWhite40"
                    android:textSize="13sp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Start button -->
        <TextView
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0.35"
            android:background="@drawable/bg_upscale_start_button_disabled"
            android:clickable="false"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="@string/string_ai_upscale_start"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
