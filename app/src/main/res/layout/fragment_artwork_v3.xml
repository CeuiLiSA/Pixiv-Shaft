<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v3_bg">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never" />

        <!-- Scroll progress bar -->
        <View
            android:id="@+id/scroll_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="top"
            android:background="@drawable/v3_scroll_progress"
            android:elevation="10dp"
            android:scaleX="0"
            android:transformPivotX="0dp" />

        <!-- Fixed nav bar -->
        <FrameLayout
            android:id="@+id/nav_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:elevation="8dp"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/nav_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="start"
                android:background="@drawable/v3_nav_btn_bg"
                android:contentDescription="@null"
                android:padding="9dp"
                android:src="@drawable/icon_navi_back"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/nav_download"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/v3_nav_btn_bg"
                    android:contentDescription="@null"
                    android:padding="9dp"
                    android:src="@drawable/ic_file_download_black_24dp"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/nav_bookmark"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/v3_nav_btn_bg"
                    android:contentDescription="@null"
                    android:padding="9dp"
                    android:src="@drawable/ic_favorite_black_24dp"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/nav_more"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/v3_nav_btn_bg"
                    android:contentDescription="@null"
                    android:padding="9dp"
                    android:src="@drawable/ic_more_vert_black_24dp"
                    app:tint="@color/white" />
            </LinearLayout>
        </FrameLayout>

    </FrameLayout>

</layout>
