<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_rate_dialog"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Heart icon -->
        <ImageView
            android:id="@+id/heart_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_rate_heart"
            tools:ignore="ContentDescription" />

        <!-- Title -->
        <TextView
            android:id="@+id/rate_title"
            style="@style/textMontserratBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/rate_dialog_title"
            android:textColor="@color/text00"
            android:textSize="22sp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/rate_subtitle"
            style="@style/textMontserratMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/rate_dialog_subtitle"
            android:textColor="@color/text20"
            android:textSize="14sp" />

        <!-- Animated Stars Row -->
        <LinearLayout
            android:id="@+id/stars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_rate_star_container"
            android:clipChildren="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/star_1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_rate_star_outline"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/star_2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_rate_star_outline"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/star_3"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_rate_star_outline"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/star_4"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_rate_star_outline"
                tools:ignore="ContentDescription" />

            <ImageView
                android:id="@+id/star_5"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_rate_star_outline"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <!-- Primary Button: Rate Now -->
        <TextView
            android:id="@+id/btn_rate_now"
            style="@style/textMontserratSemiBold"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_rate_button_primary"
            android:gravity="center"
            android:includeFontPadding="false"
            android:stateListAnimator="@animator/button_press_alpha"
            android:text="@string/rate_dialog_rate_now"
            android:textColor="@color/always_white"
            android:textSize="16sp" />

        <!-- Secondary Button: Maybe Later -->
        <TextView
            android:id="@+id/btn_maybe_later"
            style="@style/textMontserratMedium"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rate_button_secondary"
            android:gravity="center"
            android:includeFontPadding="false"
            android:stateListAnimator="@animator/button_press_alpha"
            android:text="@string/rate_dialog_maybe_later"
            android:textColor="@color/text20"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
