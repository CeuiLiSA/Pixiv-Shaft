<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="novel"
            type="androidx.lifecycle.LiveData&lt;ceui.loxia.Novel>" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/series_name"
            app:layout_constraintEnd_toStartOf="@+id/bookmark"
            android:textSize="18sp"
            android:text="@{novel.title}"
            android:textStyle="bold"
            android:textColor="@color/text00"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />


        <ceui.loxia.ProgressImageButton
            android:id="@+id/bookmark"
            app:ptb_progress_stroke_width="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintTop_toTopOf="@+id/title"
            android:padding="8dp"
            app:ptb_progress_width="14dp"
            android:src="@{novel.is_bookmarked() ? @drawable/icon_liked : @drawable/icon_not_liked}"
            android:layout_width="@dimen/min_widget_size"
            android:layout_height="@dimen/min_widget_size" />

        <TextView
            android:id="@+id/series_name"
            app:layout_constraintTop_toBottomOf="@+id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:text="@{`系列：` + novel.series.title}"
            visibleOrGone="@{novel.series != null &amp;&amp; novel.series.title.length() > 0}"
            android:textStyle="bold"
            android:textColor="@color/buttonTextGreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <!--
            用户反馈：作品详情页希望提供高密度可复制信息面板。
            每个 chip 点击复制对应字段。值绑定在 ViewHolder.onBind 里完成（避免 DataBinding
            条件表达式过长难维护）。
        -->
        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/info_chips"
            app:layout_constraintTop_toBottomOf="@+id/series_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:flexWrap="wrap">

            <TextView
                android:id="@+id/chip_novel_id"
                style="@style/NovelInfoChip"
                tools:text="作品ID 12345" />

            <TextView
                android:id="@+id/chip_author"
                style="@style/NovelInfoChip"
                tools:text="作者 Alice" />

            <TextView
                android:id="@+id/chip_author_id"
                style="@style/NovelInfoChip"
                tools:text="作者ID 67890" />

            <TextView
                android:id="@+id/chip_create_date"
                style="@style/NovelInfoChip"
                tools:text="发布 2024-01-15" />

            <TextView
                android:id="@+id/chip_text_length"
                style="@style/NovelInfoChip"
                tools:text="字数 5,000" />

            <TextView
                android:id="@+id/chip_total_view"
                style="@style/NovelInfoChip"
                tools:text="浏览 1.2k" />

            <TextView
                android:id="@+id/chip_total_bookmarks"
                style="@style/NovelInfoChip"
                tools:text="收藏 234" />

        </com.google.android.flexbox.FlexboxLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
