<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/reader_settings_sheet_bg"
        android:clipToOutline="true"
        android:fillViewport="true"
        android:paddingTop="4dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="28dp">
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="@drawable/reader_settings_handle"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"
                android:text="@string/comic_reader_settings"
                android:textColor="@color/v3_text_1"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <!-- 阅读模式 -->
            <include
                android:id="@+id/row_reading_mode"
                layout="@layout/item_reader_setting_segmented"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 翻页方向 -->
            <include
                android:id="@+id/row_direction"
                layout="@layout/item_reader_setting_segmented"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 缩放 -->
            <include
                android:id="@+id/row_fit_mode"
                layout="@layout/item_reader_setting_segmented"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 翻页动画 -->
            <include
                android:id="@+id/row_flip_anim"
                layout="@layout/item_reader_setting_segmented"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 亮度 -->
            <include
                android:id="@+id/row_sys_brightness"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_custom_brightness"
                layout="@layout/item_reader_setting_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 暖色护眼滤镜 -->
            <include
                android:id="@+id/row_warm_filter"
                layout="@layout/item_reader_setting_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 预载页数 -->
            <include
                android:id="@+id/row_preload"
                layout="@layout/item_reader_setting_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <!-- 开关组 -->
            <include
                android:id="@+id/row_keep_screen_on"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_immersive"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_show_page_number"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_load_original"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_volume_flip"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>

            <include
                android:id="@+id/row_tap_reversed"
                layout="@layout/item_reader_setting_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
