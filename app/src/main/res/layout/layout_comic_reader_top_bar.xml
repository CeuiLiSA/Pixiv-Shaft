<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/comic_top_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#CC000000"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/comic_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:padding="10dp"
        android:src="@drawable/ic_reader_back"
        android:tint="#FFFFFF"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/comic_reader_back" />

    <TextView
        android:id="@+id/comic_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/comic_share"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:padding="10dp"
        android:src="@drawable/ic_share_black_24dp"
        android:tint="#FFFFFF"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/string_110" />

    <ImageView
        android:id="@+id/comic_more"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:padding="10dp"
        android:src="@drawable/ic_more_vert_black_24dp"
        android:tint="#FFFFFF"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/comic_reader_more" />
</LinearLayout>
