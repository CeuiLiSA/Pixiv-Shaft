<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="series"
            type="ceui.loxia.NovelSeriesDetail" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/bookmark"
            android:textSize="16sp"
            android:text="@{series.title}"
            android:textStyle="bold"
            android:textColor="@color/buttonTextGreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />


        <ceui.loxia.ProgressImageButton
            android:id="@+id/bookmark"
            app:ptb_progress_stroke_width="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/title"
            app:layout_constraintTop_toTopOf="@+id/title"
            android:padding="8dp"
            app:ptb_progress_width="14dp"
            android:src="@{series.watchlist_added ? @drawable/icon_liked : @drawable/icon_not_liked}"
            android:layout_width="@dimen/min_widget_size"
            android:layout_height="@dimen/min_widget_size" />

        <!--
            和 NovelText 详情页保持一致：高密度可复制信息 chips。
            字段缺失的 chip 自动隐藏。值绑定在 ViewHolder.bindInfoChips。
        -->
        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/info_chips"
            app:layout_constraintTop_toBottomOf="@+id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:flexWrap="wrap">

            <TextView
                android:id="@+id/chip_series_id"
                style="@style/NovelInfoChip"
                tools:text="系列ID  12345" />

            <TextView
                android:id="@+id/chip_author"
                style="@style/NovelInfoChip"
                tools:text="作者  Alice" />

            <TextView
                android:id="@+id/chip_author_id"
                style="@style/NovelInfoChip"
                tools:text="作者ID  67890" />

            <TextView
                android:id="@+id/chip_content_count"
                style="@style/NovelInfoChip"
                tools:text="章节数  12" />

            <TextView
                android:id="@+id/chip_char_count"
                style="@style/NovelInfoChip"
                tools:text="总字数  50000" />

            <TextView
                android:id="@+id/chip_series_link"
                style="@style/NovelInfoChip"
                tools:text="系列链接" />

            <TextView
                android:id="@+id/chip_user_link"
                style="@style/NovelInfoChip"
                tools:text="作者主页" />

        </com.google.android.flexbox.FlexboxLayout>

        <TextView
            android:id="@+id/caption"
            app:layout_constraintTop_toBottomOf="@+id/info_chips"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="14sp"
            android:textColor="@color/text10"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
