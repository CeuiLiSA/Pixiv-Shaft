<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical">

    <!-- ════════════════════════════════════════════════
         Top section: Cover + Title/Meta
         ════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Cover image with badges -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="126dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/novel_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/v3_surface_2"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- R-18 badge -->
            <TextView
                android:id="@+id/badge_r18"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="6dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/v3_novel_r18_badge_bg"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:text="@string/v3_novel_r18"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Original badge -->
            <TextView
                android:id="@+id/badge_original"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/v3_novel_original_badge_bg"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:text="@string/v3_novel_original"
                android:textColor="@android:color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Multi-select indicator -->
            <ImageView
                android:id="@+id/select_indicator"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_checkbox_off"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Title / Author / Meta -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/novel_title"
                style="@style/textMontserratSemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.15"
                android:maxLines="2"
                android:textColor="@color/v3_text_1"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="崩壊スターレイル短篇小説集" />

            <!-- Author row -->
            <LinearLayout
                android:id="@+id/author_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/author_avatar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:scaleType="centerCrop"
                    app:civ_border_color="#1A08080C"
                    app:civ_border_width="1dp" />

                <TextView
                    android:id="@+id/author_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/v3_text_2"
                    android:textSize="12sp"
                    tools:text="PixivAuthor" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Meta row: type + word count + date + bookmark -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Word count chip -->
                <TextView
                    android:id="@+id/word_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/v3_novel_word_count_bg"
                    android:letterSpacing="0.02"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/v3_text_2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="12,345字" />

                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/v3_nav_btn_bg" />

                <!-- Date -->
                <TextView
                    android:id="@+id/publish_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/v3_text_3"
                    android:textSize="11sp"
                    tools:text="3小时前" />

                <!-- Bookmark button -->
                <ceui.loxia.ProgressImageButton
                    android:id="@+id/bookmark_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/icon_not_liked"
                    app:ptb_progress_stroke_width="3dp"
                    app:ptb_progress_width="14dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════
         Stats row: Views / Bookmarks / Comments
         ════════════════════════════════════════════════ -->


    <!-- ════════════════════════════════════════════════
         Tags section (compact flow)
         ════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/tags_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        tools:visibility="visible">


        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/tags_flow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:flexWrap="wrap" />
    </LinearLayout>

</LinearLayout>

