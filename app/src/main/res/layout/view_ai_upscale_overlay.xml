<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <!-- 加载中状态 -->
    <LinearLayout
        android:id="@+id/ai_loading_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/ai_progress_ring"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                app:indicatorColor="#80CCFF"
                app:indicatorSize="72dp"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="4dp"
                app:trackThickness="4dp" />

            <TextView
                android:id="@+id/ai_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0%"
                android:textColor="#80CCFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </FrameLayout>

        <TextView
            android:id="@+id/ai_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/ai_upscaling_in_progress"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/ai_eta_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#80FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- 完成状态 -->
    <LinearLayout
        android:id="@+id/ai_done_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_upscaling_complete"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/ai_view_compare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/refresh_button_background"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:stateListAnimator="@animator/button_press_alpha"
            android:text="@string/action_view_comparison"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/ai_dismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:text="@string/action_cancel"
            android:textAllCaps="false"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
