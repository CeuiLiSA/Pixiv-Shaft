<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/ai_progress_ring"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                app:indicatorColor="#80CCFF"
                app:indicatorSize="72dp"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="4dp"
                app:trackThickness="4dp" />

            <TextView
                android:id="@+id/ai_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0%"
                android:textColor="#80CCFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </FrameLayout>

        <TextView
            android:id="@+id/ai_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="AI 画质增强中"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/ai_eta_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#80FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
