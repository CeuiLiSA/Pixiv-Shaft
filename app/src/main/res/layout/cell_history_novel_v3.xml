<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/v3_glass_surface_xl"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/illust_image"
            android:layout_width="86dp"
            android:layout_height="120dp"
            android:background="@color/v3_surface_2"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/p_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/v3_badge_pages_bg"
                android:includeFontPadding="false"
                android:letterSpacing="0.1"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/type_novel"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:letterSpacing="-0.02"
                android:maxLines="2"
                android:textColor="@color/v3_text_1"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="小说标题" />

            <TextView
                android:id="@+id/author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/v3_text_2"
                android:textSize="12sp"
                tools:text="by: 作者" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:textColor="@color/v3_text_3"
                    android:textSize="11sp"
                    tools:text="2 分钟前" />

                <ImageView
                    android:id="@+id/delete_item"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/v3_nav_btn_bg"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:src="@drawable/ic_delete_black_24dp"
                    app:tint="#B31A1A2E" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
