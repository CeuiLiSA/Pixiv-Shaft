<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/v3_bg"
    app:cardCornerRadius="20dp"
    app:cardElevation="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <androidx.cardview.widget.CardView
            android:layout_width="88dp"
            android:layout_height="124dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/illust_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/v3_surface_2"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/p_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/v3_badge_pages_bg"
                android:includeFontPadding="false"
                android:letterSpacing="0.1"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/type_novel"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:letterSpacing="-0.02"
                android:maxLines="2"
                android:textColor="@color/v3_text_1"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="小说标题占位占位占位占位" />

            <TextView
                android:id="@+id/author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/v3_text_2"
                android:textSize="12sp"
                tools:text="by: 作者" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.06"
                    android:maxLines="1"
                    android:textAllCaps="true"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="2 分钟前" />

                <ImageView
                    android:id="@+id/delete_item"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/v3_glass_surface"
                    android:contentDescription="@null"
                    android:padding="7dp"
                    android:src="@drawable/ic_delete_black_24dp"
                    app:tint="@color/v3_text_3" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
