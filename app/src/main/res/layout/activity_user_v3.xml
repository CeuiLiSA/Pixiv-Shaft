<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v3_bg">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:theme="@style/AppTheme.AppBarOverlay"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/toolbar_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:contentScrim="@color/v3_bg"
                app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
                app:statusBarScrim="@android:color/transparent"
                app:titleEnabled="false">

                <!-- Banner image -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.7">

                    <View
                        android:id="@+id/banner_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_v3_banner_placeholder" />

                    <ImageView
                        android:id="@+id/banner_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_v3_banner_gradient" />

                </FrameLayout>

                <!-- Profile header overlapping banner -->
                <LinearLayout
                    android:id="@+id/profile_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="16dp"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.3">

                    <!-- Avatar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <!-- Avatar with premium ring -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <View
                                android:id="@+id/premium_ring"
                                android:layout_width="94dp"
                                android:layout_height="94dp"
                                android:background="@drawable/bg_v3_avatar_ring_premium"
                                android:visibility="gone" />

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/user_avatar"
                                android:layout_width="88dp"
                                android:layout_height="88dp"
                                android:layout_gravity="center"
                                android:scaleType="centerCrop"
                                app:civ_border_color="@color/v3_bg"
                                app:civ_border_width="3dp" />

                            <FrameLayout
                                android:id="@+id/premium_badge"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="bottom|end"
                                android:background="@drawable/bg_v3_premium_badge"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="★"
                                    android:textColor="#1A1A2E"
                                    android:textSize="12sp" />
                            </FrameLayout>
                        </FrameLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <!-- Actions: message + follow -->
                        <ImageView
                            android:id="@+id/msg_btn"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_v3_msg_btn"
                            android:padding="10dp"
                            android:src="@drawable/ic_baseline_mail_outline_24"
                            android:visibility="gone"
                            app:tint="@color/v3_text_2" />

                        <FrameLayout
                            android:id="@+id/follow_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <ceui.loxia.ProgressTextButton
                                android:id="@+id/follow"
                                android:layout_width="wrap_content"
                                android:layout_height="42dp"
                                android:background="@drawable/bg_v3_pill_primary"
                                android:gravity="center"
                                android:paddingHorizontal="28dp"
                                android:text="@string/follow"
                                android:textColor="@color/v3_text_1"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                app:ptb_progress_stroke_width="3dp"
                                app:ptb_progress_width="14dp" />

                            <ceui.loxia.ProgressTextButton
                                android:id="@+id/unfollow"
                                android:layout_width="wrap_content"
                                android:layout_height="42dp"
                                android:background="@drawable/bg_v3_pill_secondary"
                                android:gravity="center"
                                android:paddingHorizontal="28dp"
                                android:text="@string/unfollow"
                                android:textColor="#E6C4B5FD"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                app:ptb_progress_stroke_width="3dp"
                                app:ptb_progress_width="14dp" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/user_name"
                        style="@style/textMontserratSemiBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/v3_text_1"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="ひとはﾁｬﾝ" />

                    <!-- Handle + ID -->
                    <TextView
                        android:id="@+id/user_handle"
                        style="@style/textMontserratMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/v3_text_3"
                        android:textSize="13sp"
                        tools:text="@hitohachan · ID: 62059105" />
                </LinearLayout>

                <!-- Toolbar (pinned) -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="pin"
                    app:navigationIcon="@drawable/ic_arrow_back_white_shadow">

                    <TextView
                        android:id="@+id/toolbar_title"
                        style="@style/textMontserratBold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:alpha="0.0"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="@color/v3_text_1"
                        android:textSize="18sp" />

                    <ImageView
                        android:id="@+id/more_action"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="end"
                        android:padding="10dp"
                        android:src="@drawable/ic_more_vert_black_24dp"
                        android:visibility="gone"
                        app:tint="@color/v3_text_1" />
                </androidx.appcompat.widget.Toolbar>

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/v3_text_1"
                    android:visibility="invisible" />

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/v3_bg"
            android:clipToPadding="false"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <!-- Bio -->
                <TextView
                    android:id="@+id/bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.78"
                    android:autoLink="all"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/v3_text_1"
                    android:textColorLink="#3D8BFD"
                    android:textIsSelectable="true"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Stats Row (following + mypixiv only) -->
                <LinearLayout
                    android:id="@+id/stats_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_v3_surface"
                    android:orientation="horizontal"
                    android:paddingVertical="16dp">

                    <LinearLayout
                        android:id="@+id/stat_following"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/stat_following_num"
                            style="@style/textMontserratBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/v3_stat_following_num"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="16" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="@string/v3_label_following"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/stat_mypixiv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/stat_mypixiv_num"
                            style="@style/textMontserratBold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/v3_stat_mypixiv_num"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="@string/v3_label_mypixiv"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Social Links -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/socials_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:flexWrap="wrap" />

                <!-- Quick Navigation Tags -->
                <TextView
                    android:id="@+id/nav_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="0.12"
                    android:text="@string/v3_label_navigate"
                    android:textAllCaps="true"
                    android:textColor="@color/v3_text_3"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.zhy.view.flowlayout.TagFlowLayout
                    android:id="@+id/nav_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <!-- Profile Details Card -->
                <LinearLayout
                    android:id="@+id/profile_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/v3_glass_surface_xl"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/profile_header_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:letterSpacing="0.12"
                            android:text="@string/v3_label_profile_details"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/profile_arrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:rotation="180"
                            android:src="@drawable/ic_arrow_right_little"
                            app:tint="@color/v3_text_3" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/profile_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Workspace Card -->
                <LinearLayout
                    android:id="@+id/workspace_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/v3_glass_surface_xl"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/workspace_header_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:letterSpacing="0.12"
                            android:text="@string/v3_label_workspace"
                            android:textAllCaps="true"
                            android:textColor="@color/v3_text_3"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/workspace_arrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:rotation="180"
                            android:src="@drawable/ic_arrow_right_little"
                            app:tint="@color/v3_text_3" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/workspace_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Mute User Strip -->
                <LinearLayout
                    android:id="@+id/mute_strip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_v3_mute_strip"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/block_this_users_work"
                        android:textColor="@color/v3_text_2"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/mute_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Bottom spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
