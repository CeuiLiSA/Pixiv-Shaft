<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Stats card: Views + Bookmarks -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/v3_glass_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="16dp">

                <!-- Views -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ceui.pixiv.ui.detail.GradientTextView
                        android:id="@+id/stat_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.03"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:gtv_endColor="@color/v3_stat_views_end"
                        app:gtv_startColor="@color/v3_stat_views_start"
                        tools:text="1,627" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:letterSpacing="0.1"
                        android:text="@string/v3_label_views"
                        android:textAllCaps="true"
                        android:textColor="@color/v3_text_3"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="4dp"
                    android:background="@color/v3_border_1" />

                <!-- Bookmarks -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ceui.pixiv.ui.detail.GradientTextView
                        android:id="@+id/stat_bookmarks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.03"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:gtv_endColor="@color/v3_stat_bookmarks_end"
                        app:gtv_startColor="@color/v3_stat_bookmarks_start"
                        tools:text="298" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:letterSpacing="0.1"
                        android:text="@string/v3_label_bookmarks"
                        android:textAllCaps="true"
                        android:textColor="@color/v3_text_3"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <ceui.pixiv.ui.detail.ShimmerOverlayView
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Detail panel: metadata chips -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/v3_glass_surface_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/detail_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.12"
                        android:text="@string/novel_profile_title"
                        android:textAllCaps="true"
                        android:textColor="@color/v3_text_3"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_arrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▾"
                        android:textColor="@color/v3_text_3"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/info_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:flexWrap="wrap">

                    <TextView
                        android:id="@+id/chip_novel_id"
                        style="@style/NovelInfoChip"
                        tools:text="ID  12345" />

                    <TextView
                        android:id="@+id/chip_text_length"
                        style="@style/NovelInfoChip"
                        tools:text="字数  5000" />

                    <TextView
                        android:id="@+id/chip_total_view"
                        style="@style/NovelInfoChip"
                        tools:text="浏览  1234" />

                    <TextView
                        android:id="@+id/chip_total_bookmarks"
                        style="@style/NovelInfoChip"
                        tools:text="收藏  234" />

                    <TextView
                        android:id="@+id/chip_create_date"
                        style="@style/NovelInfoChip"
                        tools:text="发布  2024-01-15" />

                    <TextView
                        android:id="@+id/chip_author"
                        style="@style/NovelInfoChip"
                        tools:text="作者  Alice" />

                    <TextView
                        android:id="@+id/chip_author_id"
                        style="@style/NovelInfoChip"
                        tools:text="作者ID  67890" />

                    <TextView
                        android:id="@+id/chip_novel_link"
                        style="@style/NovelInfoChip"
                        tools:text="作品链接" />

                    <TextView
                        android:id="@+id/chip_user_link"
                        style="@style/NovelInfoChip"
                        tools:text="作者主页" />
                </com.google.android.flexbox.FlexboxLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</layout>
