<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/cell_bookmark_thumb"
        android:layout_width="64dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cell_bookmark_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/rank_text_color"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/cell_bookmark_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/rank_text_color"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/cell_bookmark_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/view_history_title"
            android:textSize="11sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/cell_bookmark_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="10dp"
        android:src="@drawable/ic_close_black_24dp"
        android:tint="@color/rank_text_color"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/string_46" />
</LinearLayout>
