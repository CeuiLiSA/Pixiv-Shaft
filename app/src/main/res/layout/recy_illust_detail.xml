<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/illust"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/loading_placeholder"
            android:scaleType="fitCenter">

        </ImageView>

        <include
            android:id="@+id/progress_layout"
            layout="@layout/item_progress" />

        <Button
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:visibility="gone"
            android:id="@+id/reload"
            android:layout_centerInParent="true"
            android:text="@string/string_73">

        </Button>

        <!-- V3 only: bottom-scrim + glass pill for the "展开剩余 X 张" CTA.
             CollapsibleIllustAdapter toggles visibility on pos-0 when collapsed. -->
        <FrameLayout
            android:id="@+id/expand_overlay"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@drawable/bg_v3_first_page_scrim"
            android:layout_alignBottom="@+id/illust"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/expand_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_v3_expand_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="9dp">

                    <ImageView
                        android:id="@+id/expand_chevron"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_collections_black_24dp"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/expand_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/comic_reader_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_v3_expand_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="9dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_baseline_menu_book_24"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:text="@string/comic_reader_enter"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </RelativeLayout>


</layout>
