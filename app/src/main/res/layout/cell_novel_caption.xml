<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="novel"
            type="androidx.lifecycle.LiveData&lt;ceui.loxia.Novel>" />
    </data>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/publish_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/text_length"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/total_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/illust_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@{`ID: ` + String.valueOf(novel.id)}"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/illust_link"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/user_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@{`UID: ` + String.valueOf(novel.user.id)}"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/user_link"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />


        <TextView
            android:id="@+id/caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text00"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/copy_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/copy_caption"
            android:textColor="@color/buttonTextGreen"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</layout>
