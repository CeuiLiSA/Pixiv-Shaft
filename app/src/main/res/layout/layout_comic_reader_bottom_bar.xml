<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/comic_bottom_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:paddingHorizontal="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/comic_progress_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:gravity="center" />

        <SeekBar
            android:id="@+id/comic_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/comic_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:minWidth="44dp"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="2dp">

        <ImageView
            android:id="@+id/comic_btn_prev_series"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_baseline_arrow_back_ios_24"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_prev_series" />

        <ImageView
            android:id="@+id/comic_btn_pages"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_reader_chapters"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_pages" />

        <ImageView
            android:id="@+id/comic_btn_direction"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_reader_series"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_direction" />

        <ImageView
            android:id="@+id/comic_btn_settings"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_reader_settings"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_settings" />

        <ImageView
            android:id="@+id/comic_btn_theme"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_reader_theme"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_theme" />

        <ImageView
            android:id="@+id/comic_btn_next_series"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_chevron_right_black_24dp"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/comic_reader_next_series" />
    </LinearLayout>
</LinearLayout>
